{
  "experiment_name": "momentum_batch_v5_processed",
  "strategy": "momentum_batch",
  "asset_files": {
    "hs300": "data/processed/hs300.csv",
    "zz500": "data/processed/zz500.csv",
    "cyb": "data/processed/cyb.csv",
    "dividend": "data/processed/dividend.csv"
  },
  "lookbacks": [20, 60],
  "rebalance_freqs": [20, 60],
  "top_ns": [1, 2, 3],
  "unit_costs": [0.0002, 0.0004],
  "risk": {
    "min_aligned_days": 250,
    "max_single_asset_weight": 0.5,
    "max_daily_loss_limit": 0.08,
    "max_drawdown_limit": 0.15,
    "max_rebalance_turnover": 0.8
  },
  "research": {
    "topic": "A股风格 ETF 动量轮动参数收敛",
    "round": "round_1",
    "objective": "在多年份样本上验证 lookback、Top N 和调仓频率对收益、回撤与成本的影响方向，并输出更稳健的 P0 研究证据",
    "sample_split": {
      "mode": "ratio",
      "in_sample_ratio": 0.7
    },
    "walk_forward": {
      "train_ratio": 0.5,
      "test_ratio": 0.25,
      "max_windows": 2,
      "min_train_rows": 120,
      "min_test_rows": 65
    },
    "hypotheses": [
      {
        "id": "H1",
        "statement": "较短 lookback 更适合当前 ETF 池",
        "rule": "prefer_short_lookback",
        "preferred_max_lookback": 20,
        "min_return_delta": 0.003
      },
      {
        "id": "H2",
        "statement": "Top 2 / Top 3 比 Top 1 更稳",
        "rule": "prefer_higher_top_n",
        "preferred_min_top_n": 2,
        "min_return_delta": 0.0
      },
      {
        "id": "H3",
        "statement": "较慢调仓更能控制成本并保持表现",
        "rule": "prefer_slower_rebalance",
        "preferred_min_rebalance_freq": 60,
        "min_return_delta": -0.002
      }
    ]
  },
  "output_dir": "output/momentum_batch_v5_processed"
}
